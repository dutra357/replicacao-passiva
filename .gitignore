# =========================================================
# Java + Spring Boot .gitignore
# =========================================================

# =========================================================
# Compiled class files
# =========================================================
*.class

# =========================================================
# Log files
# =========================================================
*.log
logs/
*.out

# =========================================================
# Package files
# =========================================================
*.jar
*.war
*.ear

# Keep wrapper jar
!gradle/wrapper/gradle-wrapper.jar

# =========================================================
# Maven
# =========================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Maven Wrapper
.mvn/wrapper/maven-wrapper.jar

# =========================================================
# Gradle
# =========================================================
.gradle/
build/
out/

# Gradle Wrapper
!gradle/wrapper/gradle-wrapper.jar

# =========================================================
# IntelliJ IDEA
# =========================================================
.idea/
*.iws
*.iml
*.ipr

# =========================================================
# Eclipse
# =========================================================
.project
.classpath
.settings/
.springBeans
.sts4-cache/

# =========================================================
# VS Code
# =========================================================
.vscode/

# =========================================================
# NetBeans
# =========================================================
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# =========================================================
# MacOS
# =========================================================
.DS_Store

# =========================================================
# Windows
# =========================================================
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================================================
# Linux
# =========================================================
*~

# =========================================================
# Environment variables
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# Spring Boot
# =========================================================
application-local.yml
application-local.properties
application-dev.yml
application-dev.properties
application-prod.yml
application-prod.properties

# =========================================================
# Temporary files
# =========================================================
tmp/
temp/
*.tmp
*.swp
*.swo

# =========================================================
# Test reports
# =========================================================
surefire-reports/
failsafe-reports/

# =========================================================
# Coverage reports
# =========================================================
coverage/
jacoco.exec
/site/jacoco/

# =========================================================
# Docker
# =========================================================
docker-data/
*.pid

# =========================================================
# Kubernetes
# =========================================================
*.kubeconfig

# =========================================================
# Secrets / certificates
# =========================================================
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

# =========================================================
# Cache
# =========================================================
.cache/
.cache-loader/

# =========================================================
# Generated files
# =========================================================
generated/
bin/

# =========================================================
# SonarQube
# =========================================================
.sonar/

# =========================================================
# Hibernate
# =========================================================
hibernate.log

# =========================================================
# Spring Tools
# =========================================================
.factorypath

# =========================================================
# Misc
# =========================================================
replay_pid*
hs_err_pid*